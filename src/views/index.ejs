      <h3>Works Offline</h3>
      <p class="card-text">Keep working anywhere.</p>
    </div>
  </div>
  <div class="card">
    <div class="icon-text">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
