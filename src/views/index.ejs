<%- include('partials/header') %>

<!-- Hero Section -->
<div class="hero container">
  <!-- height should be 100vh -->
  <h1><%= APP.NAME %></h1>
  <h2>Capture now. Sync later.</h2>
  <p>An offline-first task manager that never interrupts your flow.</p>
  <div class="btn-group">
    <a href="<%= ROUTES.TASKS %>" class="btn">Open <%= APP.NAME %></a>
    <a
      href="<%= APP.LINKS.DOCS %>"
      class="btn secondary"
      target="_blank"
      rel="noopener noreferrer"
      >Read Docs</a
    >
  </div>
</div>

<!-- What is -->
<div class="container">
  <h2>What is <%= APP.NAME %>?</h2>
  <p>Designed for developers and students who already use Notion</p>
  <ul class="check-list">
    <li>Fast capture</li>
    <li>Simple workflow</li>
    <li>Powered by the Notion API</li>
    <li>Clean interface</li>
  </ul>
</div>

<!-- Features -->
<div class="container">
  <h2>Features</h2>
  <div class="card">
    <div class="icon-text">
      <!--Flex space around-->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        fill="currentColor"
        class="bi bi-lightning-charge-fill"
        viewBox="0 0 16 16"
      >
        <path
          d="M11.251.068a.5.5 0 0 1 .227.58L9.677 6.5H13a.5.5 0 0 1 .364.843l-8 8.5a.5.5 0 0 1-.842-.49L6.323 9.5H3a.5.5 0 0 1-.364-.843l8-8.5a.5.5 0 0 1 .615-.09z"
        />
      </svg>
      <h3>Instant Capture</h3>
      <p class="card-text">
        No waiting for network requests. Every task is saved immediately.
      </p>
    </div>
  </div>
  <div class="card">
    <div class="icon-text">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        fill="currentColor"
        class="bi bi-card-checklist"
        viewBox="0 0 16 16"
