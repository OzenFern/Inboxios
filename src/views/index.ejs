        />
      </svg>
      <h3>Open Source</h3>
      <p class="card-text">Customize it however you like.</p>
    </div>
  </div>
</div>

<!-- Tech Stack -->
<div class="container">
  <h2>Tech Stack</h2>
  <ul class="badge-list">
    <li>Node.js</li>
    <li>Express</li>
    <li>Axios</li>
    <li>EJS</li>
    <li>Notion API</li>
    <li>CSS</li>
  </ul>
</div>

<%- include('partials/footer') %>
