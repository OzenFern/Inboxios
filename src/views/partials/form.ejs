<!-- <button command="show-modal" commandfor="task-dialog"><%#= title %></button> -->

<dialog id="task-dialog" data-mode="<%= mode %>">
    <form id="task-form">
        <h2>
            <%= mode === "create"
                ? "Create Task"
                : "Edit Task" %>
        </h2>
        <div class="form-group">
            <label for="title">
                Title
            </label>
            <input
                id="title"
                name="title"
                type="text"
                value="<%= task?.title ?? '' %>"
                required>
        </div>
        <div class="form-group">
            <label for="status">
                Status
            </label>
            <select
                id="status"
                name="status">
                <% STATUS.forEach(status => { %>
                    <option
                        value="<%= status %>"
                        <%= task?.status === status ? "selected" : "" %>
                    >
                        <%= status %>
                    </option>
                <% }) %>
            </select>
        </div>
        <fieldset>
            <legend>Due Date</legend>
            <div class="form-group">
                <label for="start">
                    Start
                </label>
                <input
                    id="start"
                    name="startDate"
                    type="datetime-local"
                    value="<%= task?.startDate ?? '' %>">
            </div>
            <div class="form-group">
                <label for="end">
                    End
                </label>
                <input
                    id="end"
                    name="endDate"
                    type="datetime-local"
                    value="<%= task?.endDate ?? '' %>">
            </div>
        </fieldset>
        <div class="btn-group">
            <button
                type="button"
                command="close"
                commandfor="task-dialog">
                Cancel
            </button>
            <button>
                <%= mode === "create"
                    ? "Create Task"
                    : "Save Changes" %>
            </button>
        </div >
    </form>
</dialog>